{
  "name": "ics-guard-api",
  "version": "1.0.0",
  "description": "ICS-Guard (Industrial Control Systems Guard) Backend API",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "prestart": "npm run swagger",
    "start": "node src/app.js",
    "predev": "npm run swagger",
    "dev": "node --watch src/app.js",
    "test:unit": "node --import ./tests/helpers/preload.js --test tests/**/*.test.js",
    "test": "npm run test:unit",
    "swagger": "node swagger.js"
  },
  "dependencies": {
    "amqplib": "^0.10.3",
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "mqtt": "^5.5.5",
    "node-telegram-bot-api": "^0.66.0",
    "nodemailer": "^6.9.13",
    "socket.io": "^4.7.5",
    "swagger-autogen": "^2.23.7",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.0"
  }
}
